{
    "[php]": {
        "editor.defaultFormatter": "bmewburn.vscode-intelephense-client"
    },
    "editor.cursorBlinking": "solid",
    "editor.cursorWidth": 5,
    "editor.fontLigatures": true,
    "editor.fontSize": 13,
    "editor.minimap.enabled": false,
    "editor.mouseWheelZoom": true,
    "editor.renderWhitespace": "trailing",
    "editor.rulers": [],
    "explorer.autoReveal": false,
    "git.autofetch": true,
    "shellcheck.disableVersionCheck": true,
    "telemetry.enableTelemetry": false,
    "terminal.external.linuxExec": "/usr/bin/tilix",
    "terminal.integrated.fontFamily": "'Hack Nerd Font'",
    "terminal.integrated.fontSize": 15,
    "window.title": "${activeEditorLong}",
    "workbench.startupEditor": "newUntitledFile",
    "files.exclude": {
        "**/__pycache__": true,
        "**/_site": true,
        "**/.DS_Store": true,
        "**/.git": true,
        "**/.hg": true,
        "**/.pytest_cache": true,
        "**/.svn": true,
        "**/*.asset-cache": true,
        "**/*.cache": true,
        "**/*.coverage": true,
        "**/*.egg-info": true,
        "**/*.jekyll-cache": true,
        "**/*.pyc": true,
        "**/*.tweet-cache": true,
        "**/bower_components": true,
        "**/celerybeat-schedule": true,
        "**/CVS": true,
        "**/node_modules": true,
        "**/tmp": true,
        "**/.trunk/*actions/": true,
        "**/.trunk/*logs/": true,
        "**/.trunk/*notifications/": true,
        "**/.trunk/*out/": true,
        "**/.trunk/*plugins/": true
    },
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "window.zoomLevel": 0,
    "terminal.integrated.rendererType": "dom",
    "workbench.statusBar.visible": true,
    "editor.fontFamily": "'IntelOneMono','Fira Code','Fira Mono','Droid Sans Mono', monospace,'monospace', 'Droid Sans Fallback', 'Noto Color Emoji'",
    "markdown.extension.tableFormatter.normalizeIndentation": true,
    "intelephense.completion.fullyQualifyGlobalConstantsAndFunctions": true,
    "workbench.colorTheme": "Dracula Theme Soft",
    "extensions.ignoreRecommendations": false,
    "git.enableSmartCommit": true,
    "editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",.<>/?",
    "namespaceResolver.highlightOnOpen": true,
    "bracketPairColorizer.activeScopeCSS": [
        "borderStyle : solid",
        "borderWidth : 1px",
        "borderColor : {color}; opacity: 0.5"
    ],
    "[blade]": {
        "editor.defaultFormatter": "shufo.vscode-blade-formatter"
    },
    "blade.format.enable": true,
    // "bladeFormatter.format.wrapAttributes": "preserve-aligned",
    "bladeFormatter.format.wrapLineLength": 9999,
    "bladeFormatter.format.wrapAttributes": "force-expand-multiline",
    "workbench.editorAssociations": {
        "*.ipynb": "jupyter.notebook.ipynb"
    },
    "editor.stickyTabStops": true,
    "markdown-checkbox.strikeThroughWhenChecked": false,
    "insertDateString.format": "YYYY-MM-DD",
    "redhat.telemetry.enabled": true,
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "security.workspace.trust.untrustedFiles": "open",
    "[markdown]": {
        "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
    },
    "[ini]": {},
    "git.openRepositoryInParentFolders": "always",
    "vscode-note.notespath": "/mnt/worktop/home/Documents/notes/",
    "vsicons.dontShowNewVersionMessage": true,
    "git.ignoreRebaseWarning": true,
    "ansible.lightspeed.suggestions.enabled": false,
    "github.copilot.nextEditSuggestions.enabled": true,
    "files.watcherExclude": {
        "**/.trunk/*actions/": true,
        "**/.trunk/*logs/": true,
        "**/.trunk/*notifications/": true,
        "**/.trunk/*out/": true,
        "**/.trunk/*plugins/": true
    },
    "editor.defaultFormatter": "trunk.io",
    "files.associations": {
        "*.toml": "ini"
    },
    "betterAlign.surroundSpace": {
        "colon": [
            0,
            1
        ],
        "assignment": [
            1,
            1
        ],
        "arrow": [
            1,
            1
        ],
        "comment": 4
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "dev.containers.defaultExtensions": [
        "Github.copilot"
    ],
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": true
        },
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "yaml.schemas": {
        "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/ansible.json#/$defs/playbook": [
            "file:///var/home/joe/Documents/src/Ansible/ansible-rk1-cluster/tasks/traefik3.yml",
            "file:///var/home/joe/Documents/src/Ansible/ansible-rk1-cluster/deploy.yml",
            "file:///var/home/joe/Documents/src/Ansible/ansible-rk1-cluster/tasks/arr/deluge.yml"
        ],
        "file:///var/home/joe/.vscode/extensions/continue.continue-1.2.16-linux-x64/config-yaml-schema.json": [
            ".continue/**/*.yaml"
        ],
        "https://www.schemastore.org/traefik-v3.json": [
            "file:///mnt/worktop/home/Documents/src/Ansible/docker-deploy/files/traefik3/traefik.yml",
            "file:///mnt/worktop/home/Documents/src/Ansible/docker-deploy/files/traefik3/dynamic_config/tls_config.yml",
            "file:///mnt/worktop/home/Documents/src/Ansible/docker-deploy/files/traefik3/dynamic_config/external.yml",
            "file:///mnt/worktop/home/Documents/src/Ansible/docker-deploy/files/traefik/traefik.yml"
        ],
        "https://json.schemastore.org/yamllint.json": "file:///home/joe/Documents/src/ansible/ansible-network/roles/docker-dashy/files/conf.yml",
        "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/ansible.json": "file:///mnt/worktop/home/Documents/src/Ansible/docker-deploy/tasks/traefik.yml",
        "https://www.schemastore.org/traefik-v2.json": [
            "file:///var/home/joe/Documents/src/Ansible/ansible-network/roles/docker-traefik/files/traefik.yml",
            "file:///var/home/joe/Documents/src/Ansible/ansible-network/roles/arr/docker-traefik/files/traefik.yml"
        ],
        "file:///var/home/joe/.vscode/extensions/continue.continue-1.2.17-linux-x64/config-yaml-schema.json": [
            ".continue/**/*.yaml"
        ]
    },
    "workbench.settings.applyToAllProfiles": [
        "yaml.schemaStore.url"
    ],
    "[yaml]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "keep",
        "diffEditor.ignoreTrimWhitespace": false,
        "editor.defaultColorDecorators": "never",
        "editor.quickSuggestions": {
            "strings": true,
            "other": true,
            "comments": false
        }
    },
    "chat.customAgentInSubagent.enabled": true,
    "inlineChat.defaultModel": "Auto (copilot)",
    "inlineChat.enableV2": true,
    "github.copilot.chat.anthropic.tools.websearch.allowedDomains": [
        "localhost",
        "localhost:11434"
    ],
    "chat.agent.thinking.phrases": {
        "mode": "replace",
        "phrases": [
            "Bribing the hamster",
            "Reticulating splines",
            "Untangling the spaghetti"
        ]
    },
    "git.addAICoAuthor": "chatAndAgent",
    "workbench.editor.useModal": "some",
    "github.copilot.chat.anthropic.tools.websearch.enabled": true,
    "chat.edits2.enabled": true
}